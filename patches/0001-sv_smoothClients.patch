diff --git a/code/server/sv_snapshot.c b/code/server/sv_snapshot.c
index e790ab25..00000005 100644
--- a/code/server/sv_snapshot.c
+++ b/code/server/sv_snapshot.c
@@ -23,6 +23,130 @@ Foundation, Inc., 51 Franklin St, Fifth Floor, Boston, MA  02110-1301  USA
 #include "server.h"


+/*
+=============================================================================
+
+Per-client position ring buffer for sv_velSmooth.
+
+Records player origin + velocity each server frame.  Used to compute
+exponential-weighted-average velocity (sv_velSmooth) for TR_LINEAR trDelta,
+which eliminates per-tick velocity jitter that manifests as blur or
+micro-stutter for fast-moving players.
+
+=============================================================================
+*/
+
+#define SV_SMOOTH_MAX_SLOTS 32
+
+typedef struct {
+	vec3_t      origin;
+	vec3_t      velocity;
+	int         serverTime;
+	qboolean    valid;
+} svSmoothPos_t;
+
+typedef struct {
+	svSmoothPos_t slots[SV_SMOOTH_MAX_SLOTS];
+	int           head;
+	int           count;
+} svSmoothHistory_t;
+
+static svSmoothHistory_t sv_smoothHistory[MAX_CLIENTS];
+
+
+void SV_SmoothInit( void ) {
+	Com_Memset( sv_smoothHistory, 0, sizeof( sv_smoothHistory ) );
+}
+
+
+void SV_SmoothClearClient( int clientNum ) {
+	if ( clientNum >= 0 && clientNum < MAX_CLIENTS )
+		Com_Memset( &sv_smoothHistory[clientNum], 0, sizeof( sv_smoothHistory[0] ) );
+}
+
+
+static void SV_SmoothRecord( int clientNum ) {
+	svSmoothHistory_t *hist;
+	svSmoothPos_t *slot;
+	int idx;
+
+	if ( clientNum < 0 || clientNum >= sv.maxclients )
+		return;
+
+	hist = &sv_smoothHistory[clientNum];
+	idx = ( hist->head % SV_SMOOTH_MAX_SLOTS + SV_SMOOTH_MAX_SLOTS ) % SV_SMOOTH_MAX_SLOTS;
+	slot = &hist->slots[idx];
+
+	if ( svs.clients[clientNum].netchan.remoteAddress.type == NA_BOT ) {
+		sharedEntity_t *gent = SV_GentityNum( clientNum );
+		VectorCopy( gent->s.pos.trBase, slot->origin );
+		VectorCopy( gent->s.pos.trDelta, slot->velocity );
+	} else {
+		playerState_t *ps = SV_GameClientNum( clientNum );
+		VectorCopy( ps->origin, slot->origin );
+		VectorCopy( ps->velocity, slot->velocity );
+	}
+
+	slot->serverTime = sv.time;
+	slot->valid = qtrue;
+
+	hist->head++;
+	if ( hist->count < SV_SMOOTH_MAX_SLOTS )
+		hist->count++;
+}
+
+
+void SV_SmoothRecordAll( void ) {
+	int i;
+	for ( i = 0; i < sv.maxclients; i++ ) {
+		if ( svs.clients[i].state == CS_ACTIVE ) {
+			SV_SmoothRecord( i );
+		}
+	}
+}
+
+
+/*
+=============
+SV_SmoothGetAverageVelocity
+
+Compute exponential-weighted-average velocity over the last windowMs.
+Each step back in time halves the weight, keeping the most-recent sample
+dominant.  This eliminates the trajectory kink at snapshot boundaries
+that a uniform sliding window would cause.
+=============
+*/
+static qboolean SV_SmoothGetAverageVelocity( int clientNum, int windowMs,
+		vec3_t outVelocity ) {
+	svSmoothHistory_t *hist;
+	int i, idx;
+	int cutoff;
+	float weight, totalWeight;
+	vec3_t weightedSum;
+
+	if ( clientNum < 0 || clientNum >= sv.maxclients )
+		return qfalse;
+
+	hist = &sv_smoothHistory[clientNum];
+	if ( hist->count == 0 )
+		return qfalse;
+
+	cutoff = sv.time - windowMs;
+	VectorClear( weightedSum );
+	totalWeight = 0.0f;
+	weight = 1.0f;
+
+	for ( i = 0; i < hist->count; i++ ) {
+		idx = ( ( hist->head - 1 - i ) % SV_SMOOTH_MAX_SLOTS + SV_SMOOTH_MAX_SLOTS ) % SV_SMOOTH_MAX_SLOTS;
+
+		if ( !hist->slots[idx].valid )
+			continue;
+		if ( hist->slots[idx].serverTime < cutoff )
+			break;
+
+		weightedSum[0] += hist->slots[idx].velocity[0] * weight;
+		weightedSum[1] += hist->slots[idx].velocity[1] * weight;
+		weightedSum[2] += hist->slots[idx].velocity[2] * weight;
+		totalWeight += weight;
+		weight *= 0.5f;
+	}
+
+	if ( totalWeight < 1e-6f )
+		return qfalse;
+
+	outVelocity[0] = weightedSum[0] / totalWeight;
+	outVelocity[1] = weightedSum[1] / totalWeight;
+	outVelocity[2] = weightedSum[2] / totalWeight;
+
+	return qtrue;
+}
+
+
 /*
 =============================================================================

@@ -571,8 +695,85 @@ static void SV_BuildCommonSnapshot( void )
 	for ( i = 0 ; i < count ; i++, index = (index+1) % svs.numSnapshotEntities ) {
 		//index %= svs.numSnapshotEntities;
 		svs.snapshotEntities[ index ] = list[ i ]->s;
-		sf->ents[ i ] = &svs.snapshotEntities[ index ];
+
+		/*
+		 * sv_smoothClients: rewrite TR_INTERPOLATE player entities to TR_LINEAR.
+		 *
+		 * The game QVM writes player entity state with TR_INTERPOLATE, which
+		 * tells the client "just lerp between snapshots."  At higher sv_fps the
+		 * client-side interpolation window shrinks and discrete position snaps
+		 * become visible as jitter.
+		 *
+		 * TR_LINEAR tells the client: "here is position AND velocity --
+		 * extrapolate forward."  This produces smooth continuous motion
+		 * regardless of tick rate.
+		 *
+		 * Velocity is optionally smoothed via sv_velSmooth (exponential weighted
+		 * average over the ring buffer) to eliminate per-tick jitter in trDelta.
+		 */
+		if ( sv_smoothClients && sv_smoothClients->integer ) {
+			entityState_t *es = &svs.snapshotEntities[ index ];
+			if ( es->number < sv.maxclients
+					&& es->pos.trType == TR_INTERPOLATE
+					&& svs.clients[ es->number ].netchan.remoteAddress.type != NA_BOT ) {
+				playerState_t *ps = SV_GameClientNum( es->number );
+				vec3_t origin, velocity, finalVel;
+				int velSmoothMs = 0;
+
+				VectorCopy( ps->origin, origin );
+				VectorCopy( ps->velocity, velocity );
+
+				/* Resolve smoothed velocity */
+				if ( sv_velSmooth && sv_velSmooth->integer != 0 ) {
+					velSmoothMs = sv_velSmooth->integer;
+					if ( velSmoothMs < 0 ) {
+						/* Auto: 4 frames at current tick rate */
+						velSmoothMs = 4 * ( 1000 / sv_fps->integer );
+					}
+				}
+				if ( velSmoothMs > 0 ) {
+					vec3_t avgVel;
+					if ( SV_SmoothGetAverageVelocity( es->number, velSmoothMs, avgVel ) ) {
+						VectorCopy( avgVel, finalVel );
+					} else {
+						VectorCopy( velocity, finalVel );
+					}
+				} else {
+					VectorCopy( velocity, finalVel );
+				}
+
+				if ( DotProduct( finalVel, finalVel ) > 100.0f ) {
+					/* Moving: stamp TR_LINEAR with position + smoothed velocity */
+					VectorCopy( origin, es->pos.trBase );
+					VectorCopy( finalVel, es->pos.trDelta );
+					es->pos.trType = TR_LINEAR;
+					es->pos.trTime = sv.time;
+				} else {
+					/* Idle: keep TR_INTERPOLATE but anchor position + time */
+					VectorCopy( origin, es->pos.trBase );
+					VectorCopy( finalVel, es->pos.trDelta );
+					es->pos.trTime = sv.time;
+				}
+
+				/* Sync es->origin to resolved trBase so client code that reads
+				   currentState.origin directly sees the same position. */
+				VectorCopy( es->pos.trBase, es->origin );
+			}
+		}
+
+		/* Anchor trTime for TR_INTERPOLATE client entities unconditionally.
+		   BG_PlayerStateToEntityState (game QVM) never writes pos.trTime for
+		   TR_INTERPOLATE -- it stays at 0 or stale.  Cgame QVM patches that
+		   redirect TR_INTERPOLATE -> TR_LINEAR need a valid trTime or the
+		   formula  trBase + trDelta * (evalTime - trTime) / 1000  produces
+		   an enormous dt, teleporting entities every frame.
+		   With trTime == sv.time:
+		     - Normal interpolation: dt = 0 at snap time -> returns trBase
+		     - Extrapolation: dt = cg.time - serverTime -> correct forward move */
+		{
+			entityState_t *es = &svs.snapshotEntities[ index ];
+			if ( es->number < sv.maxclients
+					&& es->pos.trType == TR_INTERPOLATE ) {
+				es->pos.trTime = sv.time;
+			}
+		}
+
+		sf->ents[ i ] = &svs.snapshotEntities[ index ];
 	}
 }


