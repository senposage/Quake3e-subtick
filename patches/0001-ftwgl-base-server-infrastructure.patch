+            client->multiview.protocol = 0;
+            client->multiview.scoreQueryTime = 0;
+#ifdef USE_MV_ZCMD
+            client->multiview.z.deltaSeq = 0; // reset on leaving multiview state
+#endif
+        }
+    }
+}
