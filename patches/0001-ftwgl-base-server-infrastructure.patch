+*/
+static int SV_CountQueue( const client_t *cl ) {
+	int count = 0;
+	const netchan_buffer_t *buf = cl->netchan_start_queue;
+	while ( buf ) {
+		count++;
+		buf = buf->next;
+	}
+	return count;
+}
